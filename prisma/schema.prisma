generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  role         String         @default("member")
  companyId    String
  createdAt    DateTime       @default(now())
  company      Company?        @relation(fields: [companyId], references: [id])
  chatSessions ChatSession[]
  imageGenerations ImageGeneration[]
  auditLogs    AuditLog[]
  aiCallLogs   AiCallLog[]
  creditLedgers CreditLedger[]
  rechargeOrders RechargeOrder[]
  usageRecords UsageRecord[]
  sessions     UserSession[]
  paymentOrders PaymentOrder[]
}

model Company {
  id             String             @id @default(uuid())
  name           String
  logo           String?
  industry       String?
  description    String?
  plan           String             @default("free")
  createdAt      DateTime           @default(now())
  users          User[]
  knowledgeSpaces KnowledgeSpace[]
  documents      Document[]
  knowledgeChunks KnowledgeChunk[]
  chatSessions   ChatSession[]
  skills         Skill[]
  imageGenerations ImageGeneration[]
  assets         Asset[]
  auditLogs      AuditLog[]
  apiCredentials ApiCredential[]
  aiCallLogs     AiCallLog[]
  subscriptions  Subscription[]
  creditAccount  CreditAccount?
  creditGrants   CreditGrant[]
  creditLedgers  CreditLedger[]
  rechargeOrders RechargeOrder[]
  usageRecords   UsageRecord[]
  paymentOrders  PaymentOrder[]
}

model KnowledgeSpace {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  isAiEnabled Boolean    @default(true)
  visibility  String     @default("all")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company?    @relation(fields: [companyId], references: [id])
  documents   Document[]
}

model Document {
  id               String           @id @default(uuid())
  companyId        String
  knowledgeSpaceId String
  filename         String
  fileType         String
  fileUrl          String?
  fileSize         Int?
  extractedText    String?
  status           String           @default("pending")
  sensitivityLevel String           @default("normal")
  tags             String?
  uploadedBy       String?
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company?          @relation(fields: [companyId], references: [id])
  knowledgeSpace   KnowledgeSpace   @relation(fields: [knowledgeSpaceId], references: [id])
  chunks           KnowledgeChunk[]
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  documentId String
  companyId  String
  content    String
  embedding  String?
  metadata   String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
}

model ChatSession {
  id        String        @id @default(uuid())
  companyId String
  userId    String
  mode      String        @default("knowledge")
  skillId   String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company?       @relation(fields: [companyId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  sources   String?
  metadata  String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Skill {
  id                     String    @id @default(uuid())
  companyId              String?
  name                   String
  category               String
  description            String
  sourceInspiration      String?
  framework              String?
  diagnosticQuestions    String?
  requiredKnowledgeTypes String?
  systemPrompt           String
  outputSchema           String?
  suitableQuestions      String?
  enabled                Boolean   @default(true)
  isBuiltIn              Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  company                Company?  @relation(fields: [companyId], references: [id])
}

model ImageGeneration {
  id              String   @id @default(uuid())
  companyId       String
  userId          String
  sessionTitle    String?
  prompt          String
  revisedPrompt   String?
  imageUrl        String?
  sourceImageUrl  String?
  model           String?
  size            String?
  aspectRatio     String?
  purpose         String?
  style           String?
  storageProvider String?
  storageKey      String?
  rawProviderUrl  String?
  metadata        String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  company         Company?  @relation(fields: [companyId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Asset {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  type       String   @default("image")
  url        String
  title      String?
  tags       String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  company    Company?  @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  targetType String?
  targetId   String?
  ip         String?
  result     String?
  createdAt  DateTime @default(now())
  company    Company?  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model ApiCredential {
  id           String   @id @default(uuid())
  companyId    String
  provider     String
  encryptedKey String?
  baseUrl      String?
  model        String?
  extraConfig  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company?  @relation(fields: [companyId], references: [id])
  @@unique([companyId, provider])
}

model AiCallLog {
  id               String   @id @default(uuid())
  companyId        String
  userId           String?
  mode             String   @default("knowledge")
  model            String?
  modelStatus      String?  // "live" | "mock" | "error"
  questionPreview  String?  // 前 200 字
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int?
  success          Boolean  @default(false)
  errorMessage     String?
  sourcesCount     Int?
  createdAt        DateTime @default(now())
  company          Company?  @relation(fields: [companyId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
}

model Lead {
  id           String   @id @default(uuid())
  companyName  String
  contactName  String
  contact      String
  industry     String?
  teamSize     String?
  currentTool  String?
  painPoint    String?
  note         String?
  status       String   @default("new")
  source       String   @default("website")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id                 String         @id @default(uuid())
  code               String         @unique
  name               String
  monthlyPrice       Int            @default(0)
  yearlyPrice        Int            @default(0)
  monthlyCredits     Int            @default(0)
  maxMembers         Int            @default(3)
  maxKnowledgeSpaces Int            @default(3)
  storageLimitBytes  BigInt         @default(0)
  featuresJson       String?
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]
}

model Subscription {
  id           String   @id @default(uuid())
  companyId    String
  planId       String
  billingCycle String   @default("trial")
  status       String   @default("trialing")
  startedAt    DateTime @default(now())
  expiresAt    DateTime?
  autoRenew    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id])
  plan         Plan     @relation(fields: [planId], references: [id])
  @@index([companyId, status])
  @@index([expiresAt])
}

model CreditAccount {
  id               String   @id @default(uuid())
  companyId        String   @unique
  totalBalance     Int      @default(0)
  packageBalance   Int      @default(0)
  purchasedBalance Int      @default(0)
  bonusBalance     Int      @default(0)
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CreditGrant {
  id              String         @id @default(uuid())
  companyId       String
  sourceType      String
  sourceId        String?
  originalAmount  Int
  remainingAmount Int
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
  company         Company        @relation(fields: [companyId], references: [id])
  ledgers         CreditLedger[]
  @@index([companyId, expiresAt])
  @@index([companyId, sourceType])
}

model CreditLedger {
  id             String       @id @default(uuid())
  companyId      String
  userId         String?
  grantId        String?
  type           String
  featureType    String?
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  requestId      String?
  idempotencyKey String       @unique
  description    String?
  metadataJson   String?
  createdAt      DateTime     @default(now())
  company        Company      @relation(fields: [companyId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])
  grant          CreditGrant? @relation(fields: [grantId], references: [id])
  @@index([companyId, createdAt])
  @@index([companyId, featureType])
  @@index([requestId])
}

model RechargeOrder {
  id                 String   @id @default(uuid())
  orderNo            String   @unique
  companyId          String
  userId             String?
  amountCents        Int
  baseCredits        Int
  bonusCredits       Int      @default(0)
  firstRechargeBonus Int      @default(0)
  provider           String   @default("manual")
  status             String   @default("pending")
  providerOrderNo    String?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id])
  user               User?    @relation(fields: [userId], references: [id])
  @@index([companyId, status])
  @@index([createdAt])
}

model UsageRecord {
  id                 String   @id @default(uuid())
  companyId          String
  userId             String?
  featureType        String
  requestId          String?
  model              String?
  inputTokens        Int?
  outputTokens       Int?
  imageCount         Int?
  chargedCredits     Int      @default(0)
  estimatedCostCents Int      @default(0)
  success            Boolean  @default(false)
  errorCode          String?
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id])
  user               User?    @relation(fields: [userId], references: [id])
  @@index([companyId, createdAt])
  @@index([companyId, featureType])
  @@index([requestId])
}

model UserSession {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PaymentOrder {
  id                    String   @id @default(uuid())
  orderNo               String   @unique
  companyId             String
  userId                String?
  orderType             String
  provider              String
  status                String   @default("pending")
  amountCents           Int
  currency              String   @default("CNY")
  subject               String
  description           String?
  planCode              String?
  billingCycle          String?
  rechargeOptionId      String?
  baseCredits           Int      @default(0)
  bonusCredits          Int      @default(0)
  firstRechargeBonus    Int      @default(0)
  providerOrderNo       String?
  providerTransactionId String?  @unique
  qrCodeUrl             String?
  paymentPayloadJson    String?
  paidAt                DateTime?
  expiresAt             DateTime?
  closedAt              DateTime?
  refundedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id])
  user                  User?    @relation(fields: [userId], references: [id])
  @@index([companyId, status])
  @@index([createdAt])
  @@index([expiresAt])
}
