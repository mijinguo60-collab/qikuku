generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipBillingPeriodStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  INVALIDATED
}

enum CompanyEntitlementType {
  ALL_MODELS_PERMANENT
}

enum CompanyEntitlementSourceType {
  MONTHLY_MILESTONE
  ANNUAL_PURCHASE
  SUPER_AGENT_SELF_COMPANY
  ADMIN_GRANT
  LEGACY_MIGRATION
}

enum MembershipPointGrantRunStatus {
  PENDING
  PROCESSING
  GRANTED
  FAILED
  SKIPPED
  REVERSED
}

enum CreditGrantType {
  WELCOME
  MEMBERSHIP
  RECHARGE_BASE
  RECHARGE_BONUS
  AGENT_DEMO
  AGENT_LEAD
  MANUAL_ADJUSTMENT
  LEGACY_UNKNOWN
}

enum MembershipBillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String?        @unique
  phone        String?        @unique
  phoneE164    String?        @unique
  passwordHash String?
  avatarUrl    String?
  phoneVerifiedAt DateTime?
  status       String         @default("active")
  lastLoginAt  DateTime?
  updatedAt    DateTime       @default(now()) @updatedAt
  role         String         @default("member")
  companyId    String?
  createdAt    DateTime       @default(now())
  company      Company?        @relation(fields: [companyId], references: [id])
  chatSessions ChatSession[]
  imageGenerations ImageGeneration[]
  auditLogs    AuditLog[]
  aiCallLogs   AiCallLog[]
  creditLedgers CreditLedger[]
  rechargeOrders RechargeOrder[]
  usageRecords UsageRecord[]
  sessions     UserSession[]
  paymentOrders PaymentOrder[]
  identities   AuthIdentity[]
  passwordCredential PasswordCredential?
  passwordLoginAttempts PasswordLoginAttempt[]
  memberships  CompanyMembership[]
  invitationsSent CompanyInvitation[] @relation("InvitationInviter")
  platformAuditLogs PlatformAuditLog[]
}

model PasswordCredential {
  id                String   @id @default(uuid())
  userId            String   @unique
  passwordHash      String
  passwordUpdatedAt DateTime @default(now())
  failedAttempts    Int      @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])
}

model PasswordLoginAttempt {
  id          String   @id @default(uuid())
  userId      String?
  phoneHash   String
  ipHash      String
  deviceHash  String
  attemptedAt DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneHash, attemptedAt])
  @@index([ipHash, attemptedAt])
  @@index([deviceHash, attemptedAt])
}

model Company {
  id             String             @id @default(uuid())
  name           String
  logo           String?
  industry       String?
  description    String?
  plan           String             @default("free")
  status         String             @default("active")
  createdAt      DateTime           @default(now())
  users          User[]
  knowledgeSpaces KnowledgeSpace[]
  documents      Document[]
  knowledgeChunks KnowledgeChunk[]
  chatSessions   ChatSession[]
  skills         Skill[]
  imageGenerations ImageGeneration[]
  assets         Asset[]
  auditLogs      AuditLog[]
  apiCredentials ApiCredential[]
  aiCallLogs     AiCallLog[]
  subscriptions  Subscription[]
  creditAccount  CreditAccount?
  membershipBillingPeriods MembershipBillingPeriod[]
  entitlementGrants        CompanyEntitlementGrant[]
  membershipPointGrantRuns MembershipPointGrantRun[]
  creditGrants   CreditGrant[]
  creditLedgers  CreditLedger[]
  rechargeOrders RechargeOrder[]
  usageRecords   UsageRecord[]
  paymentOrders  PaymentOrder[]
  memberships    CompanyMembership[]
  invitations    CompanyInvitation[]
}

model KnowledgeSpace {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  isAiEnabled Boolean    @default(true)
  visibility  String     @default("all")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company?    @relation(fields: [companyId], references: [id])
  documents   Document[]
}

model Document {
  id               String           @id @default(uuid())
  companyId        String
  knowledgeSpaceId String
  filename         String
  fileType         String
  fileUrl          String?
  fileSize         Int?
  extractedText    String?
  status           String           @default("pending")
  sensitivityLevel String           @default("normal")
  tags             String?
  uploadedBy       String?
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company?          @relation(fields: [companyId], references: [id])
  knowledgeSpace   KnowledgeSpace   @relation(fields: [knowledgeSpaceId], references: [id])
  chunks           KnowledgeChunk[]
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  documentId String
  companyId  String
  content    String
  embedding  String?
  metadata   String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
}

model ChatSession {
  id        String        @id @default(uuid())
  companyId String
  userId    String
  mode      String        @default("knowledge")
  skillId   String?
  modelId   String?
  providerModelId String?
  knowledgeSpaceIds String?
  webSearchEnabled Boolean @default(false)
  status    String        @default("active")
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company?       @relation(fields: [companyId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@index([companyId, userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  sources   String?
  metadata  String?
  modelId   String?
  providerModelId String?
  skillId   String?
  knowledgeSpaceIds String?
  webSearchEnabled Boolean @default(false)
  attachmentIds String?
  inputTokens Int?
  outputTokens Int?
  creditsUsed Int?
  estimatedCost Int?
  latencyMs Int?
  status String @default("completed")
  errorCode String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Skill {
  id                     String    @id @default(uuid())
  companyId              String?
  name                   String
  category               String
  description            String
  sourceInspiration      String?
  framework              String?
  diagnosticQuestions    String?
  requiredKnowledgeTypes String?
  systemPrompt           String
  outputSchema           String?
  suitableQuestions      String?
  enabled                Boolean   @default(true)
  isBuiltIn              Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  company                Company?  @relation(fields: [companyId], references: [id])
}

model ImageGeneration {
  id              String   @id @default(uuid())
  companyId       String
  userId          String
  sessionTitle    String?
  prompt          String
  revisedPrompt   String?
  imageUrl        String?
  sourceImageUrl  String?
  model           String?
  size            String?
  aspectRatio     String?
  purpose         String?
  style           String?
  storageProvider String?
  storageKey      String?
  rawProviderUrl  String?
  metadata        String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  company         Company?  @relation(fields: [companyId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Asset {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  type       String   @default("image")
  url        String
  title      String?
  tags       String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  company    Company?  @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  targetType String?
  targetId   String?
  ip         String?
  result     String?
  createdAt  DateTime @default(now())
  company    Company?  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model PlatformAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String?
  companyId   String?
  reason      String?
  beforeData  Json?
  afterData   Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id])
  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([companyId, createdAt])
}

model ApiCredential {
  id           String   @id @default(uuid())
  companyId    String
  provider     String
  encryptedKey String?
  baseUrl      String?
  model        String?
  extraConfig  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company?  @relation(fields: [companyId], references: [id])
  @@unique([companyId, provider])
}

model AiCallLog {
  id               String   @id @default(uuid())
  companyId        String
  userId           String?
  mode             String   @default("knowledge")
  model            String?
  modelStatus      String?  // "live" | "mock" | "error"
  questionPreview  String?  // 前 200 字
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int?
  success          Boolean  @default(false)
  errorMessage     String?
  sourcesCount     Int?
  createdAt        DateTime @default(now())
  company          Company?  @relation(fields: [companyId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
}

model Lead {
  id           String   @id @default(uuid())
  companyName  String
  contactName  String
  contact      String
  industry     String?
  teamSize     String?
  currentTool  String?
  painPoint    String?
  note         String?
  status       String   @default("new")
  source       String   @default("website")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id                 String         @id @default(uuid())
  code               String         @unique
  name               String
  monthlyPrice       Int            @default(0)
  yearlyPrice        Int            @default(0)
  monthlyCredits     Int            @default(0)
  maxMembers         Int            @default(3)
  maxKnowledgeSpaces Int            @default(3)
  storageLimitBytes  BigInt         @default(0)
  featuresJson       String?
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]
}

model Subscription {
  id             String                    @id @default(uuid())
  companyId      String
  planId         String
  billingCycle   String                    @default("trial")
  status         String                    @default("trialing")
  startedAt      DateTime                  @default(now())
  expiresAt      DateTime?
  autoRenew      Boolean                   @default(false)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  company        Company                   @relation(fields: [companyId], references: [id])
  plan           Plan                      @relation(fields: [planId], references: [id])
  billingPeriods MembershipBillingPeriod[]
  pointGrantRuns MembershipPointGrantRun[]

  @@index([companyId, status])
  @@index([expiresAt])
}

model CreditAccount {
  id               String   @id @default(uuid())
  companyId        String   @unique
  totalBalance     Int      @default(0)
  packageBalance   Int      @default(0)
  purchasedBalance Int      @default(0)
  bonusBalance     Int      @default(0)
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CreditGrant {
  id                      String                   @id @default(uuid())
  companyId               String
  sourceType              String
  sourceId                String?
  grantType               CreditGrantType?
  originalAmount          Int
  remainingAmount         Int
  expiresAt               DateTime?
  createdAt               DateTime                 @default(now())
  company                 Company                  @relation(fields: [companyId], references: [id])
  ledgers                 CreditLedger[]
  membershipPointGrantRun MembershipPointGrantRun?
  ledgerAllocations       CreditLedgerAllocation[]

  @@index([companyId, expiresAt])
  @@index([companyId, sourceType])
  @@index([companyId, grantType])
}

model CreditLedger {
  id             String                   @id @default(uuid())
  companyId      String
  userId         String?
  grantId        String?
  type           String
  featureType    String?
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  requestId      String?
  idempotencyKey String                   @unique
  description    String?
  metadataJson   String?
  createdAt      DateTime                 @default(now())
  company        Company                  @relation(fields: [companyId], references: [id])
  user           User?                    @relation(fields: [userId], references: [id])
  grant          CreditGrant?             @relation(fields: [grantId], references: [id])
  allocations    CreditLedgerAllocation[]

  @@index([companyId, createdAt])
  @@index([companyId, featureType])
  @@index([requestId])
}

model RechargeOrder {
  id                 String   @id @default(uuid())
  orderNo            String   @unique
  companyId          String
  userId             String?
  amountCents        Int
  baseCredits        Int
  bonusCredits       Int      @default(0)
  firstRechargeBonus Int      @default(0)
  provider           String   @default("manual")
  status             String   @default("pending")
  providerOrderNo    String?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id])
  user               User?    @relation(fields: [userId], references: [id])
  @@index([companyId, status])
  @@index([createdAt])
}

model UsageRecord {
  id                 String   @id @default(uuid())
  companyId          String
  userId             String?
  featureType        String
  requestId          String?
  model              String?
  inputTokens        Int?
  outputTokens       Int?
  imageCount         Int?
  chargedCredits     Int      @default(0)
  estimatedCostCents Int      @default(0)
  success            Boolean  @default(false)
  errorCode          String?
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id])
  user               User?    @relation(fields: [userId], references: [id])
  @@index([companyId, createdAt])
  @@index([companyId, featureType])
  @@index([requestId])
}

model UserSession {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  activeCompanyId String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model AuthIdentity {
  id String @id @default(uuid())
  userId String
  provider String
  providerUserId String
  openId String? @unique
  unionId String?
  metadataJson String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields:[userId], references:[id], onDelete:Cascade)
  @@unique([provider, providerUserId])
  @@index([unionId])
}

model CompanyMembership {
  id String @id @default(uuid())
  userId String
  companyId String
  role String @default("member")
  status String @default("active")
  invitedBy String?
  joinedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields:[userId], references:[id], onDelete:Cascade)
  company Company @relation(fields:[companyId], references:[id], onDelete:Cascade)
  @@unique([userId, companyId])
  @@index([companyId,status])
}

model SmsVerification {
  id String @id @default(uuid())
  phone String
  purpose String
  codeHash String
  expiresAt DateTime
  verifiedAt DateTime?
  attemptCount Int @default(0)
  sendIp String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([phone,createdAt])
  @@index([sendIp,createdAt])
}

model SmsVerificationChallenge {
  id                 String    @id @default(uuid())
  phoneHash          String
  phoneLast4         String
  purpose            String
  codeHash           String
  expiresAt          DateTime
  consumedAt         DateTime?
  attempts           Int       @default(0)
  maxAttempts        Int
  sendStatus         String
  providerRequestId  String?
  providerStatusCode String?
  failureCategory    String?
  requestIpHash      String
  userAgentHash      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([phoneHash, purpose, createdAt])
  @@index([phoneHash, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
  @@index([providerRequestId])
  @@index([requestIpHash, createdAt])
}

model CompanyInvitation {
  id String @id @default(uuid())
  companyId String
  inviterId String
  inviteType String
  inviteCode String? @unique
  tokenHash String? @unique
  role String @default("member")
  maxUses Int @default(1)
  usedCount Int @default(0)
  boundPhone String?
  expiresAt DateTime
  status String @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields:[companyId], references:[id], onDelete:Cascade)
  inviter User @relation("InvitationInviter", fields:[inviterId], references:[id])
  @@index([companyId,status])
}

model PaymentOrder {
  id                       String                    @id @default(uuid())
  orderNo                  String                    @unique
  companyId                String
  userId                   String?
  orderType                String
  provider                 String
  status                   String                    @default("pending")
  amountCents              Int
  currency                 String                    @default("CNY")
  subject                  String
  description              String?
  planCode                 String?
  billingCycle             String?
  rechargeOptionId         String?
  baseCredits              Int                       @default(0)
  bonusCredits             Int                       @default(0)
  firstRechargeBonus       Int                       @default(0)
  providerOrderNo          String?
  providerTransactionId    String?                   @unique
  qrCodeUrl                String?
  paymentPayloadJson       String?
  paidAt                   DateTime?
  expiresAt                DateTime?
  closedAt                 DateTime?
  refundedAt               DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  company                  Company                   @relation(fields: [companyId], references: [id])
  user                     User?                     @relation(fields: [userId], references: [id])
  membershipBillingPeriods MembershipBillingPeriod[]

  @@index([companyId, status])
  @@index([createdAt])
  @@index([expiresAt])
}

model MembershipBillingPeriod {
  id                 String                        @id @default(uuid())
  companyId          String
  subscriptionId     String?
  paymentOrderId     String?
  provider           String
  externalPeriodKey  String
  planCode           String
  billingCycle       MembershipBillingCycle
  periodStart        DateTime
  periodEnd          DateTime
  status             MembershipBillingPeriodStatus @default(PENDING)
  paymentCompletedAt DateTime?
  refundedAt         DateTime?
  cancelledAt        DateTime?
  invalidatedAt      DateTime?
  invalidationReason String?
  metadataJson       Json?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  company        Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  subscription   Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentOrder   PaymentOrder?             @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  pointGrantRuns MembershipPointGrantRun[]

  @@unique([provider, externalPeriodKey])
  @@index([companyId, periodStart, periodEnd])
  @@index([companyId, billingCycle, status])
  @@index([subscriptionId, periodStart])
  @@index([paymentOrderId])
}

model CompanyEntitlementGrant {
  id               String                       @id @default(uuid())
  companyId        String
  entitlementType  CompanyEntitlementType
  sourceType       CompanyEntitlementSourceType
  sourceId         String
  sourceOrderId    String?
  grantedAt        DateTime                     @default(now())
  effectiveAt      DateTime?
  revokedAt        DateTime?
  revocationReason String?
  metadataJson     Json?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, entitlementType, sourceType, sourceId])
  @@index([companyId, entitlementType, revokedAt])
  @@index([sourceOrderId])
  @@index([sourceType, sourceId])
}

model MembershipPointGrantRun {
  id               String                        @id @default(uuid())
  companyId        String
  subscriptionId   String
  billingPeriodId  String?
  planCode         String
  grantPeriodKey   String
  grantPeriodStart DateTime
  grantPeriodEnd   DateTime
  scheduledAt      DateTime
  grantedAt        DateTime?
  points           Int
  status           MembershipPointGrantRunStatus @default(PENDING)
  creditGrantId    String?                       @unique
  idempotencyKey   String                        @unique
  attemptCount     Int                           @default(0)
  lastAttemptAt    DateTime?
  failureReason    String?
  metadataJson     Json?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  subscription  Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  billingPeriod MembershipBillingPeriod? @relation(fields: [billingPeriodId], references: [id], onDelete: SetNull)
  creditGrant   CreditGrant?             @relation(fields: [creditGrantId], references: [id], onDelete: SetNull)

  @@unique([subscriptionId, grantPeriodKey])
  @@index([companyId, status, scheduledAt])
  @@index([billingPeriodId])
  @@index([subscriptionId, grantPeriodStart])
  @@index([status, scheduledAt])
}

model CreditLedgerAllocation {
  id            String   @id @default(uuid())
  ledgerId      String
  creditGrantId String
  amount        Int
  createdAt     DateTime @default(now())

  ledger      CreditLedger @relation(fields: [ledgerId], references: [id], onDelete: Restrict)
  creditGrant CreditGrant  @relation(fields: [creditGrantId], references: [id], onDelete: Restrict)

  @@unique([ledgerId, creditGrantId])
  @@index([ledgerId])
  @@index([creditGrantId])
}
