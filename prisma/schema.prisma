generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  role         String         @default("member")
  companyId    String
  createdAt    DateTime       @default(now())
  company      Company        @relation(fields: [companyId], references: [id])
  chatSessions ChatSession[]
  imageGenerations ImageGeneration[]
  auditLogs    AuditLog[]
}

model Company {
  id             String             @id @default(uuid())
  name           String
  logo           String?
  industry       String?
  description    String?
  plan           String             @default("free")
  createdAt      DateTime           @default(now())
  users          User[]
  knowledgeSpaces KnowledgeSpace[]
  documents      Document[]
  knowledgeChunks KnowledgeChunk[]
  chatSessions   ChatSession[]
  skills         Skill[]
  imageGenerations ImageGeneration[]
  assets         Asset[]
  auditLogs      AuditLog[]
  apiCredentials ApiCredential[]
}

model KnowledgeSpace {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  isAiEnabled Boolean    @default(true)
  visibility  String     @default("all")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  documents   Document[]
}

model Document {
  id               String           @id @default(uuid())
  companyId        String
  knowledgeSpaceId String
  filename         String
  fileType         String
  fileUrl          String?
  fileSize         Int?
  extractedText    String?
  status           String           @default("pending")
  sensitivityLevel String           @default("normal")
  tags             String?
  uploadedBy       String?
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company          @relation(fields: [companyId], references: [id])
  knowledgeSpace   KnowledgeSpace   @relation(fields: [knowledgeSpaceId], references: [id])
  chunks           KnowledgeChunk[]
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  documentId String
  companyId  String
  content    String
  embedding  String?
  metadata   String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id])
}

model ChatSession {
  id        String        @id @default(uuid())
  companyId String
  userId    String
  mode      String        @default("knowledge")
  skillId   String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  sources   String?
  metadata  String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Skill {
  id                     String    @id @default(uuid())
  companyId              String?
  name                   String
  category               String
  description            String
  sourceInspiration      String?
  framework              String?
  diagnosticQuestions    String?
  requiredKnowledgeTypes String?
  systemPrompt           String
  outputSchema           String?
  suitableQuestions      String?
  enabled                Boolean   @default(true)
  isBuiltIn              Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  company                Company?  @relation(fields: [companyId], references: [id])
}

model ImageGeneration {
  id             String   @id @default(uuid())
  companyId      String
  userId         String
  sessionTitle   String?
  prompt         String
  revisedPrompt  String?
  imageUrl       String?
  sourceImageUrl String?
  model          String?
  size           String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Asset {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  type       String   @default("image")
  url        String
  title      String?
  tags       String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String
  userId     String?
  action     String
  targetType String?
  targetId   String?
  ip         String?
  result     String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model ApiCredential {
  id           String   @id @default(uuid())
  companyId    String
  provider     String
  encryptedKey String?
  baseUrl      String?
  model        String?
  extraConfig  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id])
  @@unique([companyId, provider])
}
