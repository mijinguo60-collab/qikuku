# 企库库 CVM production runtime. Copy to a root-owned file outside the repo,
# for example /etc/qikuku/production.env. Leave every real value out of Git.
NODE_ENV=production
DATABASE_REQUIRE_POSTGRES=true

# PostgreSQL runtime and direct migration URLs. Use TencentDB's protected
# private address only after its certificate SAN has been verified.
DATABASE_URL=
DATABASE_DIRECT_URL=
# Container path; Docker mounts the host CA here read-only.
DATABASE_SSL_CA_PATH=/run/secrets/tencentdb-ca.pem
# Optional comma-separated TencentDB private DNS names explicitly approved for
# strict TLS after their certificate SAN is verified.
DATABASE_PRIVATE_HOSTS=

# Required application secrets (generate unique production values).
SESSION_SECRET=
SMS_CODE_PEPPER=
CRON_SECRET=
ENCRYPTION_KEY=

# Tencent Cloud SMS. Production must use the real provider, never mock mode.
SMS_PROVIDER=tencent
SMS_TEST_MODE=false
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=
TENCENT_SMS_ENDPOINT=
SMS_CODE_TTL_SECONDS=300
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_MAX_VERIFY_ATTEMPTS=5
SMS_PHONE_HOURLY_LIMIT=5
SMS_PHONE_DAILY_LIMIT=10
SMS_IP_HOURLY_LIMIT=20

# Temporary production object storage: Vercel Blob remains supported until the
# COS adapter and object migration have completed.
BLOB_READ_WRITE_TOKEN=

# Optional AI providers. Configure only the providers this installation serves.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
GLM_API_KEY=
GLM_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=
IMAGE_EDIT_ENABLED=false
IMAGE_EDIT_API_KEY=
IMAGE_EDIT_BASE_URL=
IMAGE_EDIT_MODEL=

# Disabled unless real WeChat OAuth credentials and callback domain are ready.
WECHAT_AUTH_ENABLED=false
WECHAT_AUTH_APP_ID=
WECHAT_AUTH_APP_SECRET=
WECHAT_AUTH_CALLBACK_URL=

# Optional payment channels. Keep disabled until their verified callback URLs
# and credentials are available.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PUBLIC_KEY=
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_GATEWAY_URL=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
