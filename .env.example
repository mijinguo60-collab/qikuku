# 企库库 生产环境变量清单
# 复制此文件为 .env 并填入真实值

# 数据库 (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@hostname/database

# Vercel Blob 存储
BLOB_READ_WRITE_TOKEN=

# 语言模型 (DeepSeek / OpenAI 兼容)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GPT 系列（仅在确认 OpenAI-compatible 通道、真实模型 ID 和能力后填写）
# 不要在此处使用 B.AI 等展示名称代替上游模型 ID。
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Embedding 模型
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_MODEL=text-embedding-3-small

# 图片模型
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com
IMAGE_MODEL=dall-e-3

# Demo fallback — 生产环境必须设为 false
ENABLE_DEMO_FALLBACK=false

# NextAuth (如使用)
NEXTAUTH_URL=https://www.qikuku.cn
NEXTAUTH_SECRET=
