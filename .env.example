# 企库库 生产环境变量清单
# 复制此文件为 .env 并填入真实值

# 数据库 (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@hostname/database

# Vercel Blob 存储
BLOB_READ_WRITE_TOKEN=

# DeepSeek 系列（共享凭据；每次请求由服务端模型目录传入 providerModelId）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://01yq888.com

# GPT 系列（仅在确认 OpenAI-compatible 通道、真实模型 ID 和能力后填写）
# 不要在此处使用 B.AI 等展示名称代替上游模型 ID。
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Gemini 系列（共享凭据；模型由服务端目录按用户选择传入 providerModelId）
# 填写前请先确认当前通道支持的 /v1/models 与对话协议；不要添加 GEMINI_MODEL。
GEMINI_API_KEY=
GEMINI_BASE_URL=

# Claude 系列（共享凭据；模型由服务端目录按用户选择传入 providerModelId）
# 填写前请先确认当前通道支持的 /v1/models 与对话协议；不要添加 CLAUDE_MODEL。
CLAUDE_API_KEY=
CLAUDE_BASE_URL=

# 智谱 GLM 系列（共享凭据；模型由服务端目录按用户选择传入 providerModelId）
# 填写前请先确认当前通道支持的 /v1/models 与对话协议；不要添加 GLM_MODEL。
GLM_API_KEY=
GLM_BASE_URL=

# Embedding 模型
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_MODEL=text-embedding-3-small

# 图片模型
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com
IMAGE_MODEL=dall-e-3

# Demo fallback — 生产环境必须设为 false
ENABLE_DEMO_FALLBACK=false

# NextAuth (如使用)
NEXTAUTH_URL=https://www.qikuku.cn
NEXTAUTH_SECRET=

# 腾讯云国内短信。仅服务端读取；请将真实值仅填写到 .env.local。
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=2681658
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com
SMS_CODE_PEPPER=
SMS_CODE_TTL_SECONDS=300
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_MAX_VERIFY_ATTEMPTS=5
SMS_PHONE_HOURLY_LIMIT=5
SMS_PHONE_DAILY_LIMIT=10
SMS_IP_HOURLY_LIMIT=20
