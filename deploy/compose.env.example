# Host-only Compose values. Store the real file outside Git (for example
# /etc/qikuku/compose.env, chmod 600). It contains paths and image tags only.
QIKUKU_ENV_FILE=/etc/qikuku/production.env
DATABASE_SSL_CA_HOST_PATH=/etc/qikuku/tencentdb-ca.pem
QIKUKU_APP_PORT=3000
QIKUKU_IMAGE=qikuku:release-placeholder
QIKUKU_MIGRATOR_IMAGE=qikuku:migrator-release-placeholder
